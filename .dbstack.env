# --- Postgres via docker compose (service: db) ---
#PG_CONTAINER=db
PG_DB=petcare
PG_USER=postgres
PGPASSWORD=postgres
PG_READY_TIMEOUT=60

# Paths inside this repo
SCHEMA_FILE=./schema.sql
SEED_FILE=./seed.sql
RESET_PUBLIC=0

# Python app
##PY_EXE=python3
PY_EXE = 'py -3.11'
VENV_PATH=.venv
REQ_FILE=./requirements.txt
APP_IMPORT=app.main:app
HOST=0.0.0.0
PORT=8001
ENV_FILE=./.env

# FastAPI reads this
DATABASE_URL=postgresql://postgres:postgres@localhost:8432/petcare

# Optional
RUN_TESTS=1

SEED_TRUNCATE=1