# .env
DATABASE_URL=postgresql://postgres:postgres@localhost:8432/petcare
# examples:
# postgresql://pet:pet@postgres:5432/petdb   (inside docker network)
# postgresql://postgres:postgres@127.0.0.1:5432/postgres
# PUBLIC_BASE is optional — auto-detected from VERCEL_URL on Vercel, or set manually for other hosts
# PUBLIC_BASE=http://127.0.0.1:8001
PC_FORCE_SELECTOR_LOOP=1